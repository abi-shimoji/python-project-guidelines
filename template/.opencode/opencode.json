{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "disabled_providers": [
    "amazon-bedrock",
    "anthropic",
    "gemini",
    "lmstudio",
    "ollama",
    "openai",
    "opencode"
  ],
  "enabled_providers": ["custom-provider"],
  "share": "disabled",
  "permission": {
    "edit": "ask",
    "bash": {
      "aws *": "ask",
      "sam *": "ask",
      "mise use -g *": "deny",
      "mise use *": "ask",
      "mise install": "ask",
      "bash *": "ask",
      "bun *": "ask",
      "docker *": "ask",
      "git commit *": "ask",
      "git push": "deny",
      "git status": "allow",
      "git tag *": "ask",
      "make *": "ask",
      "node *": "ask",
      "npm *": "ask",
      "rm *": "ask",
      "rmdir *": "ask",
      "ssh *": "deny",
      "su*": "deny",
      "terraform *": "deny"
    }
  },
  "provider": {
    "sakura": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "custom-provider",
      "options": {
        "baseURL": "{env:AI_ENDPOINT}",
        "headers": {
          "apiKey": "{env:API_KEY}"
        }
      },
      "models": {
        "preview/Kimi-K2.6": {
          "name": "Kimi-K2.6"
        }
      }
    }
  }
}
